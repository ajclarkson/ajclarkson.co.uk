---
const { tags } = Astro.props;
---

<div class="tags">
    {tags.map((tag: string) => (
      <p class="tag"><a href={`/tags/${tag}`}>{tag}</a></p>
    ))}
</div>

<style>
    a {
        text-decoration: none;
        text-transform: uppercase;
    }
    
    a:link, a:visited, a:active {
      color: var(--accent-color);
    }
    a:hover {
        color: var(--link-hover-color);
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
    }

    .tag {
      font-size: 0.875em;
    }
</style>
