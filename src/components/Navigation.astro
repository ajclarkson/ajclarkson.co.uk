---
interface Props {
    segments?: { label: string; href: string }[];
}
const { segments = [] } = Astro.props;
---
<nav class="breadcrumb" aria-label="breadcrumb">
    <span class="prompt">&#62;</span>
    <a href="/" class="brand">ajclarkson</a>
    {segments.map(seg => (
        <>
            <span class="sep">/</span>
            <a href={seg.href}>{seg.label}</a>
        </>
    ))}
</nav>
