---
import { getCollection, render } from 'astro:content';
import MarkdownPostLayout from '../../layouts/MarkdownPostLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post, index) => {
  const realIndex = index + 1;
  let indexString = realIndex;
  if (realIndex < 100 && realIndex > 9 ) {
    indexString = `0${realIndex}`;
  } else if (realIndex < 10) {
    indexString = `00${realIndex}`;
  }
  return { params: { slug: post.id }, props: { post, index: indexString },} 
  });
}
const { post, index } = Astro.props;
const { Content, remarkPluginFrontmatter } = await render(post);
post.data.minutesRead = remarkPluginFrontmatter.minutesRead;
post.data.imagePath = remarkPluginFrontmatter.image;
post.data.imageAlt = remarkPluginFrontmatter.imageAlt;
post.data.description = remarkPluginFrontmatter.description;
---
<MarkdownPostLayout frontmatter={post.data} index={index}> 
  <Content />
</MarkdownPostLayout>
