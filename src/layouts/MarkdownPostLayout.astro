---
import PageLayout from './PageLayout.astro';

const { frontmatter } = Astro.props;

const postDate = new Date(frontmatter.pubDate);
const formattedDate = postDate.toLocaleDateString('en-GB', {
    day: 'numeric', month: 'long', year: 'numeric'
});
---
<PageLayout pageTitle={frontmatter.title}>
    <div class="post-header">
        {frontmatter.tags?.length > 0 && (
            <div class="post-tags">
                {frontmatter.tags.map((tag: string) => <span class="post-tag">{tag}</span>)}
            </div>
        )}
        <h1>{frontmatter.title}</h1>
        {frontmatter.description && (
            <p class="post-description">{frontmatter.description}</p>
        )}
        <div class="post-meta">
            {formattedDate}{frontmatter.minutesRead ? ` · ${frontmatter.minutesRead}` : ''}
        </div>
    </div>
    <div class="post-body">
        <slot />
    </div>
</PageLayout>
