---
layout: nil
---
<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom">
 
 <title>{{site.name}}</title>
 <link href="http://ajclarkson.co.uk/atom.xml" rel="self"/>
 <link href="http://ajclarkson.co.uk/"/>
 <updated>{{ site.time | date_to_xmlschema }}</updated>
 <id>http://ajclarkson.co.uk</id>
 <author>
   <name>Adam James Clarkson</name>
 </author>
 
 {% for post in site.categories['blog'] %}
 <entry>
   <title>{{ post.title }}</title>
   <link href="http://ajclarkson.co.uk{{ post.url }}"/>
   <updated>{{ post.date | date_to_xmlschema }}</updated>
   <id>http://ajclarkson.co.uk{{ post.id }}</id>
   <content type="html">{{ post.content | xml_escape }}</content>
 </entry>
 {% endfor %}
 
</feed>